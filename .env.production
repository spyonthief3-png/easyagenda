# Configurações de Produção - EasyAgenda
# Definir no Dashboard Vercel:
# - ALLOWED_ORIGINS: URL do seu projeto Vercel
# - JWT_SECRET: Uma chave secreta segura
# - TURSO_DATABASE_URL: URL do banco Turso
# - TURSO_AUTH_TOKEN: Token de autenticação Turso

# Exemplo para produção:
# ALLOWED_ORIGINS=https://easyagenda-neon.vercel.app
# JWT_SECRET=sua-chave-secreta-aqui
# TURSO_DATABASE_URL=libsql://...
# TURSO_AUTH_TOKEN=...
